# ── Navigation ────────────────────────────────────────────────────────────────
alias ..='cd ..'
alias ...='cd ../..'
alias ~='cd ~'

# ── Better defaults ────────────────────────────────────────────────────────────
alias ls='eza --icons --group-directories-first'
alias ll='eza -la --icons --group-directories-first'
alias lt='eza --tree --icons --level=2'
# bat is called batcat on Ubuntu
alias bat='batcat 2>/dev/null || bat'
alias cat='bat --paging=never'
alias grep='grep --color=auto'

# ── Git shortcuts ──────────────────────────────────────────────────────────────
alias gs='git status'
alias ga='git add -A'
alias gc='git commit -m'
alias gp='git push'
alias gl='git log --oneline --graph --decorate -10'
alias gd='git diff'

# ── Dotfiles ───────────────────────────────────────────────────────────────────
alias dots='cd ~/dotfiles'
alias sync='just --justfile ~/dotfiles/Justfile sync'
alias link='just --justfile ~/dotfiles/Justfile link'

# ── Dev ────────────────────────────────────────────────────────────────────────
alias dev='cd $PROJECT_PATH && npm run dev-server'
alias ws='tmuxinator start workspace'

# ── System ────────────────────────────────────────────────────────────────────
alias ports='ss -tulnp'
alias ip='curl -s ifconfig.me'
alias reload='source ~/.zshrc'

# ── Claude ────────────────────────────────────────────────────────────────────
alias claude-mem='bun "/home/hassan-jan/.claude/plugins/marketplaces/thedotmack/plugin/scripts/worker-service.cjs"'
