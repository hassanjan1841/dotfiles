# ── Navigation ────────────────────────────────────────────────────────────────
alias ..='cd ..'
alias ...='cd ../..'
alias ~='cd ~'

# ── Better defaults ────────────────────────────────────────────────────────────
alias ls='eza --icons --group-directories-first'
alias ll='eza -la --icons --group-directories-first'
alias lt='eza --tree --icons --level=2'
# bat is called batcat on Ubuntu
alias bat=batcat
alias cat='bat --paging=never'
alias grep='grep --color=auto'

# ── Git shortcuts ──────────────────────────────────────────────────────────────
alias gs='git status'
alias ga='git add -A'
alias gc='git commit -m'
alias gp='git push'
alias gl='git log --oneline --graph --decorate -10'
alias gd='git diff'

# ── Dotfiles ───────────────────────────────────────────────────────────────────
alias dots='cd ~/dotfiles'
alias sync='just --justfile ~/dotfiles/Justfile sync'
alias link='just --justfile ~/dotfiles/Justfile link'
alias tasks='just --justfile ~/dotfiles/Justfile tasks'
alias zsh-profile='just --justfile ~/dotfiles/Justfile zsh-profile'
alias keys='just --justfile ~/dotfiles/Justfile keys'

# ── Dev ────────────────────────────────────────────────────────────────────────
alias dev='npm run dev-server'
alias ws='tmuxinator start workspace'

# ── System ────────────────────────────────────────────────────────────────────
alias ports='ss -tulnp'
alias ip='curl -s ifconfig.me'
alias reload='source ~/.zshrc'
alias df=duf
alias du='ncdu --color dark'
alias top=btop

# ── Bitwarden CLI ─────────────────────────────────────────────────────────
# Unlock vault first: bw_unlock  → then: bw_get "Gmail"
bw_unlock() { export BW_SESSION="$(bw unlock --raw)"; }
bw_get()    { bw get password "$@" --session "${BW_SESSION:-}"; }

# ── Claude ────────────────────────────────────────────────────────────────────
alias claude-mem='bun "/home/hassan-jan/.claude/plugins/marketplaces/thedotmack/plugin/scripts/worker-service.cjs"'
